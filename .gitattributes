# ==========================================================
# 1. 默认设置：所有 Git 识别为文本的文件都强制使用 LF 换行符
# ==========================================================
* text=auto eol=lf

# ==========================================================
# 2. 显式指定代码与文档文件为文本，并统一换行符
# ==========================================================
# Arduino 相关源代码
*.ino      text eol=lf
*.h        text eol=lf
*.hpp        text eol=lf
*.hxx        text eol=lf
*.c        text eol=lf
*.cpp      text eol=lf
*.cc      text eol=lf
*.cxx      text eol=lf

# 文档文件
*.md       text eol=lf
*.txt      text eol=lf

# 配置文件
.gitignore     text eol=lf
.gitattributes text eol=lf

# ==========================================================
# 3. 显式指定图片及二进制文件（不进行换行符转换）
# ==========================================================
# 这里的 binary 等同于 -text -diff，确保图片数据不会被 Git 修改
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary

# ==========================================================
# 4. (可选) 如果未来涉及脚本文件
# ==========================================================
*.py       text eol=lf
*.m        text eol=lf
*.sh       text eol=lf