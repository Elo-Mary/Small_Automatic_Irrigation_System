# =========================
# 1. Arduino 编译与临时文件
# =========================
build/
*.elf
*.hex
*.bin
*.eep
*.map
*.lst
*.obj
*.core
*.out

# =========================
# 2. 本地配置与敏感信息
# =========================
# 将 Wi-Fi 密码、API Key、本地硬件路径等放在以下文件中，避免误传
config.h
secrets.h
local_settings.h

# =========================
# 3. 常见开发工具与 IDE 缓存
# =========================
# 防止团队成员使用不同的编辑器协同开发时，将本地工作区配置传到仓库
.vscode/
.vs/
.idea/
*.suo
*.sln
*.user
*.njsproj

# =========================
# 4. 操作系统缓存文件
# =========================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Trashes

# Windows
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# =========================
# 5. 视频文件 (禁止上传)
# =========================
*.mp4
*.mov
*.avi
*.wmv
*.flv
*.mkv
*.webm

# =========================
# 6. 禁止上传非 .md/.txt 的常见文档/文本格式
# =========================
# 办公文档
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx
*.odt
*.rtf